#!/usr/bin/env bash
set -e

TYPEWRITER_DIR="$HOME/.typewriter/app"
BIN_LINK="/usr/local/bin/typewriter"

case "${1:-}" in
  version|--version|-v)
    grep '"version"' "$TYPEWRITER_DIR/package.json" | head -1 | sed 's/.*"version": "\(.*\)".*/\1/'
    exit 0
    ;;

  help|--help|-h)
    echo "Usage: typewriter [command]"
    echo ""
    echo "Commands:"
    echo "  (none)       Start the notebook server"
    echo "  version      Print version"
    echo "  update       Update to latest version"
    echo "  uninstall    Uninstall Typewriter"
    echo "  help         Print this help"
    exit 0
    ;;

  update|--update)
    echo "Updating Typewriter..."
    LATEST=$(curl -fsSL https://api.github.com/repos/nikolasgioannou/typewriter/releases/latest | grep '"tag_name"' | sed 's/.*"v\(.*\)".*/\1/')
    if [ -z "$LATEST" ]; then
      echo "Failed to fetch latest version."
      exit 1
    fi
    CURRENT=$(grep '"version"' "$TYPEWRITER_DIR/package.json" | head -1 | sed 's/.*"version": "\(.*\)".*/\1/')
    if [ "$CURRENT" = "$LATEST" ]; then
      echo "Already on latest version ($CURRENT)."
      exit 0
    fi
    echo "Updating from $CURRENT to $LATEST..."
    curl -fsSL "https://github.com/nikolasgioannou/typewriter/archive/refs/tags/v${LATEST}.tar.gz" -o /tmp/typewriter-update.tar.gz
    rm -rf "$TYPEWRITER_DIR"
    mkdir -p "$TYPEWRITER_DIR"
    tar -xzf /tmp/typewriter-update.tar.gz -C "$TYPEWRITER_DIR" --strip-components=1
    rm /tmp/typewriter-update.tar.gz
    cd "$TYPEWRITER_DIR" && bun install --production
    echo "Updated to $LATEST."
    exit 0
    ;;

  uninstall|--uninstall)
    echo "Uninstalling Typewriter..."
    rm -rf "$HOME/.typewriter"
    if [ -w "$BIN_LINK" ]; then
      rm -f "$BIN_LINK"
    else
      sudo rm -f "$BIN_LINK"
    fi
    echo "Typewriter uninstalled."
    exit 0
    ;;
esac

# Start the server and capture output to detect the port
cd "$TYPEWRITER_DIR"
PIPE=$(mktemp -u)
mkfifo "$PIPE"

bun run src/server/index.ts 2>&1 | tee "$PIPE" &
SERVER_PID=$!

# Read output until we find the port
URL=""
while IFS= read -r line; do
  echo "$line"
  if [[ "$line" =~ http://localhost:([0-9]+) ]]; then
    URL="http://localhost:${BASH_REMATCH[1]}"
    break
  fi
done < "$PIPE"

rm -f "$PIPE"

# Open browser
if [ -n "$URL" ]; then
  if command -v open &> /dev/null; then
    open "$URL"
  elif command -v xdg-open &> /dev/null; then
    xdg-open "$URL"
  fi
fi

# Wait for server process
wait $SERVER_PID
